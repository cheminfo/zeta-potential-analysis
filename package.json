{
  "name": "zeta-potential-analysis",
  "version": "1.0.1",
  "license": "MIT",
  "description": "Analysis of zeta potential measurements",
  "keywords": [
    "zeta-potential",
    "zetasizer",
    "electrophoretic-mobility",
    "analysis"
  ],
  "author": "Luc Patiny",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root ZetaPotentialAnalysis",
    "check-types": "tsc --noEmit",
    "clean": "rimraf coverage lib",
    "eslint": "eslint .",
    "eslint-fix": "eslint . --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "cheminfo-types": "^1.10.0",
    "common-spectrum": "^3.1.0",
    "parse-zetasizer": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@zakodium/tsconfig": "^1.0.2",
    "cheminfo-build": "^1.3.2",
    "eslint": "^9.39.3",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/zeta-potential-analysis.git"
  },
  "bugs": {
    "url": "https://github.com/cheminfo/zeta-potential-analysis/issues"
  },
  "homepage": "https://github.com/cheminfo/zeta-potential-analysis#readme",
  "info": {
    "domain": [
      "Physical Chemistry",
      "Materials Science"
    ],
    "technique": {
      "name": "Zeta Potential",
      "chmo": "0000120"
    }
  }
}
